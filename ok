#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/scripts/ok" && pwd)"

usage() {
  cat <<'EOF'
ok — session-based orchestration manager

Usage:
  ok create <name> [--base <branch>]   Create a new session (branch + worktree)
  ok start <name> [max-iterations]     Interview → auto-execute pipeline
  ok list                              List all sessions (pm2-style)
  ok dashboard                         Live auto-refreshing dashboard
  ok logs <name> [--follow]            View session execution logs
  ok stop <name>                       Stop ralph loop
  ok qa <name>                         Enter QA mode for a session
  ok approve <name>                    Create PR and merge session
  ok destroy <name>                    Remove session and cleanup
  ok status <name>                     Show detailed session status

Lifecycle:
  create → start (interview + auto-execute) → qa → approve → destroy
EOF
}

cmd="${1:-}"
shift || true

case "$cmd" in
  create)    exec bash "$SCRIPT_DIR/create.sh" "$@" ;;
  start)     exec bash "$SCRIPT_DIR/start.sh" "$@" ;;
  list|ls)   exec bash "$SCRIPT_DIR/list.sh" "$@" ;;
  dashboard) exec bash "$SCRIPT_DIR/dashboard.sh" "$@" ;;
  logs)      exec bash "$SCRIPT_DIR/logs.sh" "$@" ;;
  stop)      exec bash "$SCRIPT_DIR/stop.sh" "$@" ;;
  qa)        exec bash "$SCRIPT_DIR/qa.sh" "$@" ;;
  approve)   exec bash "$SCRIPT_DIR/approve.sh" "$@" ;;
  destroy)   exec bash "$SCRIPT_DIR/destroy.sh" "$@" ;;
  status)    exec bash "$SCRIPT_DIR/list.sh" "$@" ;;
  help|--help|-h|"") usage ;;
  *) echo "Unknown command: $cmd" >&2; usage >&2; exit 1 ;;
esac
